# Postgres riêng của bridge (tách khỏi DB của Chatwoot)
DATABASE_URL=postgres://zca:zca@bridge-db:5432/zca
# URL gốc của Chatwoot mà bridge truy cập được
# (khớp tên service "chatwoot-rails" trong docker-compose)
CHATWOOT_BASE_URL=http://chatwoot-rails:3000
# Khóa hex 32 byte để mã hóa thông tin đăng nhập bằng AES-256-GCM. Tạo bằng: openssl rand -hex 32
CREDENTIALS_KEY=replace_me_with_openssl_rand_hex_32
# Cổng bridge lắng nghe
PORT=4000
# URL gốc của bridge truy cập được từ bên ngoài (dùng cho webhook_url của Chatwoot và iframe Dashboard App)
PUBLIC_BASE_URL=http://localhost:4000
# Access token + account id của Chatwoot Application API.
# BẮT BUỘC để bắt tin tự gửi (import các tin nhân viên gửi trực tiếp từ app Zalo vào Chatwoot dưới
# dạng tin outgoing). Cũng dùng để đăng private note trong hội thoại khi một tin gửi sang Zalo thất
# bại vĩnh viễn. Tạo tại Chatwoot: Profile Settings -> Access Token. Để trống thì không import được
# tin tự gửi (job sẽ retry rồi dead-letter) và bỏ qua thông báo lỗi.
CHATWOOT_API_ACCESS_TOKEN=
CHATWOOT_ACCOUNT_ID=
# Tùy chọn: token bắt buộc để gọi admin API (/admin/api/*). URL iframe của Dashboard App phải kèm
# ?token=<value>. Tạo bằng: openssl rand -hex 24. Để trống để tắt.
ADMIN_TOKEN=
# Tùy chọn: secret nhúng trong đường dẫn webhook (/webhooks/chatwoot/<secret>) để chỉ Chatwoot mới
# gọi được. Tạo bằng: openssl rand -hex 24. Để trống để dùng đường /webhooks/chatwoot không bảo vệ.
WEBHOOK_SECRET=
# Lưu trữ media (backup bền mọi media; sống sót khi Zalo xóa/link hết hạn)
MEDIA_ARCHIVE_ROOT=/archive
# Thời hạn link media tính bằng ngày; 0 = không hết hạn
MEDIA_TOKEN_TTL_DAYS=0
# Giới hạn dung lượng upload lên Chatwoot (MB); media lớn hơn sẽ được archive và phục vụ qua link /media
CHATWOOT_MAX_ATTACHMENT_MB=40
# Zalo OA (Official Account) — tùy chọn; chỉ cần khi kết nối kênh OA
ZALO_OA_APP_ID=
ZALO_OA_APP_SECRET=
# OA Secret Key — xác thực chữ ký (MAC) của webhook OA gửi đến. Đây là "OA Secret Key" trong
# Zalo dev console, KHÁC với ZALO_OA_APP_SECRET (dùng cho OAuth).
ZALO_OA_SECRET_KEY=
ZALO_OA_OAUTH_REDIRECT=https://your-bridge.example.com/oa/oauth/callback

# ── Full stack (chỉ dùng cho docker-compose.full.yml) ────────────────────────────
# Các biến dưới đây dựng kèm Chatwoot (rails + sidekiq + Postgres + Redis) trong cùng
# một file. Bỏ qua nếu bạn dùng docker-compose.example.yml và tự host Chatwoot riêng.
# Mật khẩu Postgres của Chatwoot (tách biệt với bridge-db)
CHATWOOT_POSTGRES_PASSWORD=replace_me_chatwoot_db_password
# Mật khẩu Redis của Chatwoot
CHATWOOT_REDIS_PASSWORD=replace_me_chatwoot_redis_password
# Khóa bí mật Rails của Chatwoot (BẮT BUỘC). Tạo bằng: openssl rand -hex 64
CHATWOOT_SECRET_KEY_BASE=replace_me_with_openssl_rand_hex_64
# URL Chatwoot truy cập từ trình duyệt (mặc định http://localhost:3000)
CHATWOOT_FRONTEND_URL=http://localhost:3000
